rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Subscriptions can only be read/written by the owner
    match /subscriptions/{subscriptionId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Chat sessions can only be read/written by the owner
    match /chatSessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Conversation history can only be read/written by the owner
    match /conversationHistory/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Usage records can only be read/written by the owner
    match /usageRecords/{recordId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Automation templates can be read by anyone, but only written by the owner
    match /automationTemplates/{templateId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}