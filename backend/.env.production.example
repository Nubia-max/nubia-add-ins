# Production Environment Configuration Template
# Copy this to .env.production and set real values

# Backend Port
BACKEND_PORT=3001

# Environment
NODE_ENV=production

# CORS Origins (production domains)
CORS_ORIGIN=https://yourdomain.com,https://excel.officeapps.live.com

# Firebase Configuration - SET THESE TO YOUR PRODUCTION VALUES
FIREBASE_PROJECT_ID=your_production_project_id
FIREBASE_CLIENT_EMAIL=your_production_service_account_email
FIREBASE_PRIVATE_KEY="your_production_private_key_here"

# AI Configuration - SET THESE TO YOUR PRODUCTION KEYS
OPENAI_API_KEY=your_production_openai_key
DEEPSEEK_API_KEY=your_production_deepseek_key

# AI Model Configuration
OPENAI_MODEL=gpt-4
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
DEEPSEEK_CHAT_MODEL=deepseek-chat

# Payment Configuration (Paystack) - SET THESE TO YOUR LIVE KEYS
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key
USD_TO_NGN_RATE=1500

# Credits Configuration
DEFAULT_FREE_CREDITS=10
CREDITS_PER_DOLLAR=100
MIN_RECHARGE_AMOUNT=2
MAX_RECHARGE_AMOUNT=100

# Security Configuration
JWT_SECRET=your_super_secure_jwt_secret
SESSION_SECRET=your_super_secure_session_secret

# Database Configuration (if using external DB)
# DATABASE_URL=your_production_database_url

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=/var/log/nubia/app.log

# SSL Configuration (if applicable)
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem