{
  "name": "nubia-excel-addin",
  "version": "1.0.0",
  "description": "Nubia Excel Add-in - AI-powered Excel automation and assistance",
  "main": "dist/taskpane.js",
  "scripts": {
    "start": "npm run dev",
    "dev": "webpack serve --mode development --open",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "serve": "webpack serve --mode development",
    "clean": "rimraf dist",
    "validate": "office-addin-manifest validate manifest.xml",
    "sideload": "office-addin-debugging start manifest.xml excel",
    "stop": "office-addin-debugging stop manifest.xml",
    "lint": "eslint src --ext .js --fix",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/office-js": "^1.0.374",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.8.1",
    "eslint": "^8.55.0",
    "html-loader": "^4.2.0",
    "html-webpack-plugin": "^5.5.3",
    "office-addin-debugging": "^5.0.15",
    "office-addin-dev-certs": "^1.13.3",
    "office-addin-lint": "^2.3.3",
    "office-addin-manifest": "^1.13.3",
    "rimraf": "^5.0.5",
    "style-loader": "^3.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "browserslist": [
    "ie 11",
    "last 2 versions"
  ],
  "keywords": [
    "excel",
    "office-addin",
    "ai",
    "automation",
    "nubia"
  ],
  "author": "Nubia Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nubia/excel-addin"
  }
}