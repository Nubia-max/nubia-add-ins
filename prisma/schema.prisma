generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  settings    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  subscriptions Subscription[]
  automations   Automation[]
  chatSessions  ChatSession[]
  usage         Usage[]
  
  @@map("users")
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  status               String
  tier                 String
  automationsLimit     Int
  automationsUsed      Int      @default(0)
  billingPeriodStart   DateTime @default(now())
  billingPeriodEnd     DateTime
  stripeSubscriptionId String?
  stripePriceId        String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("subscriptions")
}

model Automation {
  id              String   @id @default(cuid())
  userId          String
  command         String
  context         Json?
  result          Json?
  status          String
  tokensUsed      Int?
  executionTime   Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("automations")
}

model ChatSession {
  id          String   @id @default(cuid())
  userId      String
  messages    Json
  tokensUsed  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("chat_sessions")
}

model Usage {
  id              String   @id @default(cuid())
  userId          String
  type            String
  tokensUsed      Int?
  executionTime   Int?
  success         Boolean  @default(true)
  createdAt       DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("usage")
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  commands    Json
  category    String?
  isPublic    Boolean  @default(false)
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("templates")
}